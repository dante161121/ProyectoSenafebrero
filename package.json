{
  "name": "inoutmanager",
  "version": "1.0.0",
  "description": "Sistema de gestión IN OUT MANAGER - Frontend moderno con gestión de dependencias",
  "main": "frontend/proyectopages/index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "python -m http.server 8000",
    "install-deps": "npm install",
    "start:backend": "cd backend && node server.js",
    "start:frontend": "vite --strictPort",
    "start:both": "powershell -ExecutionPolicy Bypass -File .\\start-both.ps1",
    "start:windows": "powershell -ExecutionPolicy Bypass -File .\\start-both.ps1",
    "stop:both": "powershell -ExecutionPolicy Bypass -File .\\start-both.ps1 -Stop",
    "ports:status": "powershell -ExecutionPolicy Bypass -File .\\start-both.ps1 -Status",
    "clean:ports": "powershell -ExecutionPolicy Bypass -File .\\start-both.ps1 -Stop"
  },
  "keywords": [
    "frontend",
    "javascript",
    "css",
    "html",
    "responsive",
    "dashboard"
  ],
  "author": "IN OUT MANAGER Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^7.1.5"
  },
  "repository": {
    "type": "git",
    "url": "local"
  }
}
